{
    "family": "flask-task",
    "executionRoleArn": "arn:aws:iam::314431780935:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "flask-container",
            "image": "IMAGE_PLACEHOLDER",
            "portMappings": [
                {
                    "containerPort": 5000,
                    "hostPort": 5000
                }
            ],
            "essential": true
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "networkMode": "awsvpc",
    "cpu": "256",
    "memory": "512"
}